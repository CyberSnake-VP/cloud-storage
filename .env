# PostgreSQL
POSTGRES_DB=cloud_storage_db
POSTGRES_USER=cloud_user
POSTGRES_PASSWORD=cloud_pass
TZ=Europe/Moscow
# Spring DataSource
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/cloud_storage_db
SPRING_DATASOURCE_USERNAME=cloud_user
SPRING_DATASOURCE_PASSWORD=cloud_pass
# Redis
SPRING_DATA_REDIS_HOST=redis
# minIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin